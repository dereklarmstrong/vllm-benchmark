# vLLM Benchmark Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# vLLM server API endpoint (OpenAI-compatible)
VLLM_BASE_URL="http://localhost:8000/v1"

# Bearer token for authentication (leave empty if no auth required)
VLLM_AUTH_TOKEN=""

# Model ID (must match what's loaded in vLLM)
VLLM_MODEL="Qwen/Qwen2.5-7B-Instruct"

# Number of concurrent requests (default: 3)
VLLM_NUM_REQUESTS=3
